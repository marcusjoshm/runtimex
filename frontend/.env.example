# Backend API host. Used by both the REST client (axios) and the socket.io
# connection. Defaults to http://localhost:5001 when unset (see
# frontend/src/api/config.ts).
#
# Example for a deployed backend:
#   REACT_APP_API_URL=https://api.runtimex.example
#
# CRA convention: env vars must be prefixed with REACT_APP_ to be exposed to
# the browser bundle. Restart `npm start` after changing this file.
REACT_APP_API_URL=http://localhost:5001
